# Telnyx SIP Credentials (Credential-based authentication)
TELNYX_SIP_USER=softmodemuser
TELNYX_SIP_PASS=your_sip_password
TELNYX_SIP_DOMAIN=sip.telnyx.com

# Required outbound caller ID presented to Telnyx (must be a valid number on your account)
TELNYX_OUTBOUND_CID=+15551234567

# Optional caller ID display name
TELNYX_OUTBOUND_NAME=OOB-Console-Hub

# Bridge SIP/RTP settings
SIP_LOCAL_ADDR=0.0.0.0
SIP_LOCAL_RTP_PORT=20000
SIP_INVITE_TIMEOUT_SECS=60

# SSH port for OOB user access
SSH_PORT=2222

# Modem PTY exposed by slmodemd
DEVICE_PATH=/dev/ttySL0
